#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")
basedir_win="$basedir"
exe=""
msys=""

case `uname -a` in
  *CYGWIN*|*MINGW*|*MSYS*)
    if command -v cygpath > /dev/null 2>&1; then
      basedir_win=`cygpath -w "$basedir"`
    fi
    exe=".exe"
    msys="true"
  ;;
  *WSL2*)
    if command -v wslpath > /dev/null 2>&1; then
      basedir_win="$(wslpath -w "$basedir" 2> /dev/null)"
      if [ $? -ne 0 ] || [ -z "$basedir_win" ]; then
        basedir_win="$basedir"
      else
        exe=".exe"
      fi
    fi
  ;;
esac

if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../node_modules/pnpm/bin/pnpm.cjs" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
  exec node.exe  "$basedir_win/../node_modules/pnpm/bin/pnpm.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
fi
# cmd-shim-target=/Users/npttruong/projects/npt-project/kinder-pms-webapp/.pnpm-store/v11/links/@/pnpm/10.18.2/0fcbb06597967c7259d6fe387f1b455a8fe95857d4a1de3a74e84ed1a97b4fba/node_modules/pnpm/bin/pnpm.cjs
