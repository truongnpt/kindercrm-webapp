# Copy to .env.local and fill in secrets for local development.
# Public/shared vars are in .env and .env.development.

# Supabase (local: run `pnpm supabase:web:start` first)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55521
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site (dev only — production build uses .env.production HTTPS URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI Assistant (optional — fallback mode without key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# VietQR (optional — shows QR on invoice detail when balance > 0)
NEXT_PUBLIC_VIETQR_BANK_BIN=
NEXT_PUBLIC_VIETQR_ACCOUNT_NO=
NEXT_PUBLIC_VIETQR_ACCOUNT_NAME=

# Stripe SaaS billing (optional — paid plans use Checkout when set)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# VND per 1 USD for Stripe checkout conversion (default 25000 if unset)
STRIPE_VND_PER_USD=25000

# Cron jobs (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Subscription grace period before past_due → read-only (default 7)
SUBSCRIPTION_PAST_DUE_GRACE_DAYS=7

# SMTP for transactional emails (trial reminders — SUB-007)
# Production: use same provider as Supabase Auth SMTP
# Local dev: Supabase Inbucket → SMTP_HOST=127.0.0.1 SMTP_PORT=55525
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Kinder CRM

# Enterprise sales inquiries (SUB-015) — notify ops when owner submits contact form
ENTERPRISE_SALES_EMAIL=
SMTP_SECURE=false

# SaaS VAT invoices (SUB-021)
SAAS_VAT_RATE=10
SAAS_INVOICE_SELLER_NAME=Kinder CRM
SAAS_INVOICE_SELLER_TAX_CODE=
SAAS_INVOICE_SELLER_ADDRESS=
SAAS_INVOICE_SELLER_EMAIL=
